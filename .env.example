# ── LLM Provider ───────────────────────────────────────────────────────────
# Options: groq | openai
# Groq is the primary provider — fast inference, free tier available.
# Get a key at: https://console.groq.com
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.1

# ── Groq ────────────────────────────────────────────────────────────────────
# Available models: llama-3.1-8b-instant  (fast, recommended for FAQ)
#                   llama-3.3-70b-versatile (higher quality)
#                   mixtral-8x7b-32768      (balanced)
GROQ_API_KEY=your_groq_key_here

# ── OpenAI (fallback — only needed if LLM_PROVIDER=openai) ──────────────────
OPENAI_API_KEY=your_key_here

# ── Embedding Model ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Vector Store ────────────────────────────────────────────────────────────
# Options: faiss | chroma | pinecone
VECTOR_STORE=faiss
FAISS_INDEX_PATH=corpus/index/faiss.index

# Pinecone (only required if VECTOR_STORE=pinecone)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=hdfc-mf-faq

# ── Retriever ───────────────────────────────────────────────────────────────
RETRIEVER_TOP_K=5

# ── Reranker ────────────────────────────────────────────────────────────────
USE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=3

# ── Corpus ──────────────────────────────────────────────────────────────────
SOURCES_FILE=corpus/sources.json
RAW_HTML_DIR=corpus/raw
PROCESSED_DIR=corpus/processed

# ── Scraper ─────────────────────────────────────────────────────────────────
SCRAPER_DELAY_SECONDS=2
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_USER_AGENT=Mozilla/5.0 (compatible; HDFCFAQBot/1.0)

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Dev API gateway (Node) + Vite ───────────────────────────────────────────
# Run: uvicorn api.main:app --port 8000
#      cd server && npm start   # listens on 8090, proxies RAG to FastAPI, serves /api/nav/*
API_GATEWAY_PORT=8090
FASTAPI_URL=http://127.0.0.1:8000
# Optional override for frontend dev proxy (see frontend/vite.config.js)
# VITE_API_PROXY_TARGET=http://localhost:8090
